# Required
OPENAI_API_KEY=sk-your-key-here

# OpenAI models
EMBEDDING_MODEL=text-embedding-3-small
LABELING_MODEL=gpt-4o-mini

# Embedding generation
EMBEDDING_BATCH_SIZE=64
EMBEDDING_MAX_RETRIES=3

# UMAP dimensionality reduction (cosine metric on raw embeddings)
UMAP_N_NEIGHBORS=15
UMAP_N_COMPONENTS=10
UMAP_MIN_DIST=0.0
UMAP_METRIC=cosine

# HDBSCAN clustering (euclidean on UMAP-reduced space)
HDBSCAN_MIN_CLUSTER_SIZE=5
# HDBSCAN_MIN_SAMPLES=

# Topic labeling
SAMPLES_PER_CLUSTER=5

# Bot: minimum cosine similarity to assign a cluster (else unclustered / noise)
MIN_CLUSTER_SIMILARITY=0.55

# Supabase (required — PostgreSQL + pgvector + Storage bucket `proofs`)
# Tables use se_ prefix: se_analysis_runs, se_conversations, se_embeddings, etc.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres
STORAGE_BUCKET=proofs
EMBEDDING_DIMENSION=1536

# Railway / Docker (optional — temp upload dir only)
# APP_ROOT=/app
# DATA_DIR=/data/data
